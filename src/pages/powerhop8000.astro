---
import Layout from "../layouts/Layout.astro";
import ProductCarousel from "../components/ProductCarousel.astro";
import Button from "../components/Button.astro";
import frontImage from "../assets/powerhop8000/front-8000-png.png";
import faceImage from "../assets/powerhop8000/face-8000-png.png";
import backImage from "../assets/powerhop8000/back-8000-png.png";

const carouselImages = [
  {
    src: frontImage,
    alt: "Front view of Power/Hop8000",
  },
  {
    src: faceImage,
    alt: "Face view of Power/Hop8000",
  },
  {
    src: backImage,
    alt: "Back view of Power/Hop8000",
  },
];
---

<Layout Page="Product Page" Title="Product Page">
  <section class="product-page">
    <ProductCarousel images={carouselImages} />

    <div class="product-details">
      <h1>Power/Hop<span>8000</span></h1>

      <div class="productstatistics">
        <p>USABLE POWER</p>
        <p>8,000 WH</p>
        <p>SURGE PROTECT.</p>
        <p>8,000 W</p>
        <p>CHARGING TIME</p>
        <p>~4H</p>
        <p>AC INPUT</p>
        <p>90-350 V</p>
        <p>BATTERY</p>
        <p>LIFEPO₄</p>
        <p>LIFESPAN</p>
        <p>3,000+ CYCLES</p>
        <p>INVERTER</p>
        <p>4,000 W</p>
        <div class="extrafeatures">
          <p>MOBILE APPLICATION</p>
          <p>WEB PORTAL</p>
          <p>IOT TELEMETRY</p>
        </div>
      </div>

      <div class="productprice">
        <p class="price">₦90,000</p>
        <p class="billing-period">/ MONTH</p>
        <p class="startup-cost">₦0 STARTUP COST</p>
      </div>
    </div>

    <p class="product-description">
      Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi eleifend
      orci nec nunc sollicitudin venenatis. Vestibulum suscipit in quam eu
      eleifend. Suspendisse ac elit nunc. Maecenas ut urna facilisis,
      consectetur nisi eu, molestie mi. Nunc non ligula auctor dui placerat
      pharetra. Fusce eget ante convallis, congue est placerat, bibendum justo.
    </p>

    <Button
      href="/booking/"
      variant={3}
      text="GET STARTED →"
      class="sticky-get-started"
    />

    <section class="power-features">
      <h2>What can I power</h2>
      <p>
        The PowerHop 8000 is capable of powering many devices, and stores 8000W
        of usable power. When the power grid returns, it recharges automatically
        in about 4 hours, ensuring frequent uptime.
      </p>

      <div class="feature-elements">
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Lights</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Fan</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Wi-Fi</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Laptop</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>TV</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Phone</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Sewing</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>POS</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Drill</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Fridge</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Aircon</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Freezer</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Speaker</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Printer</h3>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true"></span>
          <h3>Computer</h3>
        </div>
      </div>
      <p class="feature-more">...and much more.</p>
    </section>

    <details class="specsdropdown">
      <summary>SPECIFICATIONS</summary>
      <p>
        Looking for a smaller fit? The PowerHop 2000 stores up to 2,000 Wh of
        usable power between each charging, starting at ₦36,000 / month.
      </p>
    </details>

    <section class="need-more">
      <h2>Need more</h2>
      <p>
        Browse our other PowerHop models, to find the perfect solution for your
        power needs.
      </p>

      <Button href="/services/" variant={1} text="MODELS →" />
    </section>
  </section>
</Layout>

<style>
  .product-page {
    display: grid;
    gap: 2.5rem;
    align-items: start;
    justify-items: center;
    box-sizing: border-box;
    width: min(100%, 70rem);
    margin: 0 auto;
    padding: 0 10px 5.5rem;
  }

  .product-details {
    width: min(100%, 30rem);
    justify-self: center;
  }

  h1 {
    margin: 0 0 1.25rem;
    color: #111111;
    font-family: "Barlow Condensed", Arial, Helvetica, sans-serif;
    font-size: clamp(2.7rem, 10vw, 4.1rem);
    font-weight: 900;
    line-height: 0.95;
    text-transform: uppercase;
  }

  h1 span {
    color: #008751;
  }

  h2 {
    margin: 0;
    color: #111111;
    font-family: "Barlow Condensed", Arial, Helvetica, sans-serif;
    font-size: clamp(2rem, 8vw, 2.7rem);
    font-weight: 900;
    line-height: 1;
  }

  h2::after {
    content: "?";
    color: #008751;
  }

  .product-description,
  .power-features > p,
  .need-more p {
    width: min(100%, 27rem);
    margin: 0;
    color: #737373;
    font-family: Inter, Arial, Helvetica, sans-serif;
    font-size: 1rem;
    line-height: 1.7;
  }

  .productstatistics {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    border-top: 1px solid #b5b5b5;
    border-left: 1px solid #b5b5b5;
    background: #ffffff;
  }

  .productstatistics > p,
  .extrafeatures {
    margin: 0;
    border-right: 1px solid #b5b5b5;
    border-bottom: 1px solid #b5b5b5;
    padding: 0.6rem 0.75rem;
    color: #111111;
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: clamp(0.86rem, 3vw, 1rem);
    line-height: 1.35;
    text-transform: uppercase;
  }

  .extrafeatures {
    grid-column: 1 / -1;
    min-height: 5.4rem;
  }

  .extrafeatures p {
    margin: 0 0 0.25rem;
  }

  .extrafeatures p:last-child {
    margin-bottom: 0;
  }

  .productprice {
    display: grid;
    justify-items: end;
    margin-top: 1.5rem;
    text-align: right;
  }

  .price {
    margin: 0;
    color: #008751;
    font-family: "Barlow Condensed", Arial, Helvetica, sans-serif;
    font-size: clamp(2.4rem, 10vw, 3.5rem);
    font-weight: 900;
    line-height: 0.9;
  }

  .billing-period,
  .startup-cost {
    margin: 0;
    color: #8a8a8a;
    font-family: "Inter", Arial, Helvetica, sans-serif;
    font-size: clamp(0.9rem, 3vw, 1.1rem);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .billing-period {
    margin-top: 0.35rem;
  }

  .startup-cost {
    margin-top: 1.35rem;
  }

  :global(.sticky-get-started) {
    position: sticky;
    bottom: 1rem;
    z-index: 50;
    justify-self: center;
    width: min(calc(100% - 2rem), 24rem);
    box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.18);
  }

  .specsdropdown {
    width: min(100%, 30rem);
    justify-self: center;
  }

  .specsdropdown summary {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 4rem;
    background: #000000;
    color: #f2f2f2;
    cursor: pointer;
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: 20px;
    font-weight: 400;
    letter-spacing: 0.05em;
    list-style: none;
    padding: 0 2.25rem 0 1.25rem;
    text-transform: uppercase;
  }

  .specsdropdown summary::-webkit-details-marker {
    display: none;
  }

  .specsdropdown summary::before,
  .specsdropdown summary::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 1.15rem;
    height: 0.22rem;
    border-radius: 999px;
    background: #f2f2f2;
    transition: transform 150ms ease;
  }

  .specsdropdown summary::before {
    right: 2.85rem;
    transform: translateY(-50%) rotate(45deg);
  }

  .specsdropdown summary::after {
    right: 2.1rem;
    transform: translateY(-50%) rotate(-45deg);
  }

  .specsdropdown[open] summary::before {
    transform: translateY(-50%) rotate(-45deg);
  }

  .specsdropdown[open] summary::after {
    transform: translateY(-50%) rotate(45deg);
  }

  .specsdropdown p {
    margin: 0;
    background: #1b1b1b;
    color: #f2f2f2;
    font-family: Inter, Arial, Helvetica, sans-serif;
    font-size: 15px;
    line-height: 1.55;
    padding: 1.6rem 1.8rem 1.75rem;
  }

  .power-features {
    display: grid;
    gap: 1.35rem;
    width: min(100%, 64rem);
    justify-items: center;
    justify-self: center;
    border-top: 1px solid #dddddd;
    padding-top: 2.5rem;
  }

  .power-features h2,
  .power-features > p {
    justify-self: center;
    width: min(100%, 27rem);
  }

  .power-features h2 {
    text-align: center;
  }

  .feature-elements {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.55rem 0.85rem;
    width: min(100%, 26rem);
    justify-items: center;
  }

  .feature {
    display: grid;
    justify-items: center;
    gap: 0.45rem;
    min-width: 0;
  }

  .feature-icon {
    display: block;
    width: clamp(4.4rem, 20vw, 5.5rem);
    aspect-ratio: 1;
    border-radius: 999px;
    background: #d9d9d9;
  }

  .feature h3 {
    margin: 0;
    color: #111111;
    font-family: Inter, Arial, Helvetica, sans-serif;
    font-size: 0.86rem;
    font-weight: 500;
    line-height: 1.2;
    text-align: center;
    text-transform: uppercase;
  }

  .feature-more {
    justify-self: center;
    text-align: center;
  }

  .need-more {
    display: grid;
    gap: 0.75rem;
    justify-items: center;
    width: min(100%, 27rem);
    margin: 0 auto;
  }

  @media (min-width: 56rem) {
    .product-page {
      grid-template-columns: minmax(0, 34rem) minmax(0, 30rem);
      gap: 2rem 3rem;
      justify-content: center;
      justify-items: stretch;
      align-items: start;
      width: min(calc(100% - 40px), 70rem);
      padding-right: 0;
      padding-left: 0;
    }

    .product-page :global(.product-carousel) {
      grid-column: 1;
      grid-row: 1 / span 3;
      justify-self: center;
      width: min(100%, 34rem);
    }

    .product-details {
      grid-column: 2;
      grid-row: 1;
      width: 100%;
    }

    h1 {
      font-size: clamp(3rem, 5vw, 3.7rem);
      white-space: nowrap;
    }

    .product-description {
      grid-column: 2;
      grid-row: 2;
      width: 100%;
      font-size: 0.82rem;
    }

    :global(.sticky-get-started) {
      grid-column: 2;
      grid-row: 3;
      position: static;
      width: 12.5rem;
      box-shadow: none;
    }

    .specsdropdown {
      grid-column: 1 / -1;
      grid-row: 4;
      width: min(100%, 60rem);
      justify-self: center;
    }

    .specsdropdown summary {
      min-height: 2.9rem;
      font-size: 1rem;
      padding: 0 4rem 0 5rem;
    }

    .specsdropdown summary::after {
      width: 0.95rem;
      height: 0.16rem;
    }

    .specsdropdown summary::before {
      right: 2.65rem;
      width: 0.95rem;
      height: 0.16rem;
    }

    .power-features {
      grid-column: 1 / -1;
      grid-row: 5;
      justify-self: center;
      margin-top: 2rem;
      padding-top: 4rem;
    }

    .power-features > p {
      width: 100%;
      font-size: 0.78rem;
    }

    .feature-elements {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      width: min(100%, 50rem);
      justify-self: center;
      gap: 1.35rem 1rem;
    }

    .feature-icon {
      width: 5rem;
    }

    .feature h3 {
      font-size: 0.72rem;
    }

    .need-more {
      grid-column: 1 / -1;
      grid-row: 6;
      justify-self: center;
    }
  }
</style>
