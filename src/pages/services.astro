---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import Button from "../components/Button.astro";
import ProductComparisonTable from "../components/ProductComparisonTable.astro";
import ProductCard from "../components/ProductCard.astro";
import "../styles/global.css";
import powerhop1000 from "../assets/powerhop1000/front-1000-png.png";
import powerhop2000 from "../assets/powerhop2000/front-2000-png.png";
import powerhop8000 from "../assets/powerhop8000/front-8000-png.png";
import productspread from "../assets/productspread.png";
---

<Layout Page="OurServices" Title="Our Services">
  <section class="services-page">
    <h1 class="services-title">
      Power/Hop series<span class="text-brand">:</span>
    </h1>

    <div class="services-hero">
      <Image
        src={productspread}
        alt="PowerHop product spread"
        class="productspread"
      />

      <ProductComparisonTable />
    </div>

    <div class="productcardlist">
      <ProductCard
        name="Power/Hop1000"
        description="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi eleifend orci nec nunc sollicitudin venenatis."
        image={powerhop1000}
        link="/powerhop1000/"
      />
      <ProductCard
        name="Power/Hop2000"
        description="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi eleifend orci nec nunc sollicitudin venenatis."
        image={powerhop2000}
        link="/powerhop2000/"
      />
      <ProductCard
        name="Power/Hop8000"
        description="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi eleifend orci nec nunc sollicitudin venenatis."
        image={powerhop8000}
        link="/powerhop8000/"
      />
    </div>

    <section class="service-help" aria-labelledby="service-help-title">
      <h2 id="service-help-title">
        Need a hand<span class="text-brand">?</span>
      </h2>
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi eleifend
        orci nec nunc sollicitudin venenatis.
      </p>
      <Button href="/faq/" variant={3} text="Help" class="service-help-button" />
    </section>
  </section>
</Layout>

<style>
  .services-page {
    box-sizing: border-box;
    width: min(100%, 64rem);
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .services-title {
    margin: 0 0 2rem;
    color: #111111;
    font-family: "Barlow Condensed", Arial, Helvetica, sans-serif;
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 900;
    line-height: 0.95;
    text-transform: uppercase;
  }

  .services-hero {
    display: grid;
    gap: 2rem;
    align-items: stretch;
  }

  .productspread {
    display: block;
    width: 100%;
    max-width: 34rem;
    height: auto;
    margin: 0 auto;
    object-fit: contain;
  }

  .productcardlist {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    width: 100%;
    gap: 2rem;
    justify-items: center;
    margin-top: 4rem;
  }

  .service-help {
    width: min(100%, 30rem);
    margin: 4rem auto 0;
  }

  .service-help h2 {
    margin: 0 0 1rem;
    color: #111111;
    font-family: "Barlow Condensed", Arial, Helvetica, sans-serif;
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1;
  }

  .service-help p {
    margin: 0 0 1.25rem;
    color: #737373;
    font-family: Inter, Arial, Helvetica, sans-serif;
    font-size: 1rem;
    line-height: 1.65;
  }

  :global(.service-help-button) {
    width: min(100%, 13rem);
    margin-right: auto;
    margin-left: auto;
  }

  @media (max-width: 63.9375rem) {
    .services-page {
      width: 100%;
      padding-right: 1.25rem;
      padding-left: 1.25rem;
    }

    .services-hero {
      justify-items: center;
    }

    .services-title {
      font-size: 2rem;
    }

    :global(.services-page .comparisontable) {
      width: 100%;
    }

    :global(.services-page .productcard) {
      width: 100%;
      max-width: 22.5rem;
    }

    :global(.services-page .comparisontable > *) {
      min-height: 3.35rem;
      padding: 0.6rem 0.9rem;
    }

    :global(.services-page .comparisontable p),
    :global(.services-page .productdescription),
    .service-help p {
      font-size: 12px;
    }

    :global(.services-page .productname:nth-child(1)::before),
    :global(.services-page .productname:nth-child(1)::after),
    :global(.services-page .productname:nth-child(2)::before),
    :global(.services-page .productname:nth-child(2)::after) {
      font-size: 16px;
    }

    :global(.services-page .productcard .productname),
    .service-help h2 {
      font-size: 1.5rem;
    }

    :global(.services-page .productbutton),
    :global(.service-help-button) {
      font-size: 0.75rem;
    }
  }

  @media (min-width: 42rem) {
    .productcardlist {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
    }
  }

  @media (min-width: 64rem) {
    .services-page {
      padding: 0;
    }

    .services-title {
      margin-bottom: 3.75rem;
      font-size: 3.6rem;
    }

    .services-hero {
      grid-template-columns: minmax(0, 1.35fr) minmax(20rem, 0.95fr);
      gap: 2rem;
      align-items: start;
    }

    .productspread {
      aspect-ratio: 1.35 / 1;
      height: 100%;
      max-height: 26.5rem;
      max-width: 34rem;
    }

    :global(.services-hero .comparisontable) {
      width: 100%;
    }

    :global(.services-hero .comparisontable > *) {
      min-height: 3.35rem;
      padding: 0.45rem 0.65rem;
    }

    :global(.services-hero .comparisontable p) {
      font-size: 0.72rem;
    }

    .productcardlist {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 5.5rem;
      justify-items: stretch;
      margin-top: 4rem;
    }

    :global(.productcardlist .productcard) {
      width: 100%;
      max-width: 18rem;
    }

    :global(.productcardlist .productimageframe) {
      aspect-ratio: 1 / 1.06;
    }

    :global(.productcardlist .productname) {
      margin-top: 1.2rem;
      font-size: 0.95rem;
      letter-spacing: 0.28em;
    }

    :global(.productcardlist .productdescription) {
      font-size: 0.78rem;
      line-height: 1.8;
    }

    :global(.productcardlist .productbutton) {
      min-width: 13rem;
      margin-top: 1.25rem;
      padding: 0.6rem 1rem;
      font-size: 0.85rem;
    }

    .service-help {
      margin-top: 4.25rem;
      text-align: left;
    }
  }
</style>
