---
import "../styles/global.css";
---

<footer>
  <div class="footer bg-dark-bg">
    <div class="footerContent font-sans">
      <div class="footerContact font-sans text-lg">
        <p class="footerLabel text-dark-muted mb-2">WhatsApp:</p>
        <p class="footerValue text-dark-primary mb-4">+249 123 456 7890</p>
      </div>

      <div class="footerContact font-sans text-lg">
        <p class="footerLabel text-dark-muted mb-2">Email:</p>
        <p class="footerValue text-dark-primary">power@hop.ng</p>
      </div>
      <!-- 
      <nav class="footerLink text-dark-primary" aria-label="Footer links">
        <a href="#">LINK</a>
        <a href="#">LINK</a>
      </nav> -->

      <a
        href="/"
        class="footerLogo text-dark-primary font-display font-black text-hero mt-10"
        aria-label="PowerHop home"
      >
        POWER<span class="text-brand">HOP</span>
      </a>

      <p class="copyright font-sans text-dark-muted text-sm">
        &copy; 2026 PowerHop
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin: 0 auto;
    clip-path: polygon(0 0, 100% 20.5%, 100% 100%, 0 100%);
  }

  .footerContent {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    padding: 7.5rem 4.5rem 3.6rem;
    gap: 1rem;
  }

  .footerContact {
    display: grid;
    gap: 0rem;
  }

  .footerLink {
    display: grid;
    margin-top: 0.1rem;
  }

  .footerLink a {
    width: fit-content;
    line-height: 2.35rem;
    text-decoration: none;
  }

  .footerLogo {
    width: fit-content;
    line-height: 0.82;
    text-decoration: none;
  }

  .copyright {
    letter-spacing: 0.2em;
    line-height: 2rem;
    text-transform: uppercase;
  }

  @media (max-width: 767px) {
    .footer {
      clip-path: polygon(0 0, 100% 14%, 100% 100%, 0 100%);
    }

    .footerContent {
      padding: 7.5rem 2rem 2.5rem;
    }

    .footerLabel {
      line-height: 1.7rem;
    }

    .footerValue,
    .footerLink a {
      line-height: 2rem;
    }

    .footerLogo {
      margin-top: 2rem;
    }

    .copyright {
      letter-spacing: 0.18em;
      line-height: 1.4rem;
    }
  }
</style>
