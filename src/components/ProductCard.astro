---
// src/components/ProductCard.astro
import { Image } from "astro:assets";
import Button from "./Button.astro";

interface Props {
  name: string;
  description: string;
  image: ImageMetadata;
  link: string;
  alt?: string;
}

const { name, description, image, link, alt = name } = Astro.props;
---

<div class="productcard">
  <div class="productimageframe">
    <Image src={image} alt={alt} class="product-image" width={430} />
  </div>

  <h3 class="productname">{name}</h3>
  <p class="productdescription">
    {description}
  </p>

  <Button href={link} variant={1} text={name} class="productbutton" />
</div>

<style>
  .productcard {
    width: min(100%, 22.5rem);
    color: #111111;
  }

  .productimageframe {
    display: grid;
    place-items: center;
    aspect-ratio: 1 / 1.05;
    border: 1px solid #9f9f9f;
    background: #ffffff;
    padding: 0.5rem;
  }

  .product-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .productname {
    margin: 1.25rem 0 0.75rem;
    font-family: "Inter", "Arial Nova", Arial, Helvetica, sans-serif;
    font-size: 20px;
    font-weight: 200;
    letter-spacing: 0.3em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .productdescription {
    margin: 0;
    color: #737373;
    font-family: Inter, Arial, Helvetica, sans-serif;
    font-size: clamp(1rem, 4vw, 1.1rem);
    font-weight: 500;
    line-height: 1.85;
  }

  :global(.productbutton) {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    width: fit-content;
    min-width: 16.8rem;
    margin: 1.55rem auto 0;
    padding: 0.72rem 1.15rem;
    background-color: #008751;
    border-color: #008751;
    color: #ffffff;
    font-size: clamp(1rem, 4vw, 1.25rem);
    font-weight: 800;
    line-height: 1;
  }

  :global(.productbutton)::after {
    content: "\2192";
    font-size: 1.45em;
    font-weight: 400;
    line-height: 0.75;
  }

  @media (max-width: 24rem) {
    .productimageframe {
      padding: 1rem;
    }

    :global(.productbutton) {
      width: 100%;
      min-width: 0;
    }
  }
</style>
