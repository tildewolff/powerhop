---
import logo from "../assets/logo.svg";
import "../styles/global.css";

const normalizePath = (path: string) =>
  path === "/" ? path : path.replace(/\/$/, "");
const currentPath = normalizePath(Astro.url.pathname);
const activeClass = (href: string) => {
  const normalizedHref = normalizePath(href);

  if (normalizedHref === "/") {
    return currentPath === "/" ? "active" : "";
  }

  return currentPath === normalizedHref ||
    currentPath.startsWith(`${normalizedHref}/`)
    ? "active"
    : "";
};
---

<header id="siteHeader" class="bg-light-surface">
  <div class="headerContents">
    <!-- logos -->
    <div id="mobileAlwaysVisible">
      <a
        href="/"
        class="mobileClosedLogo text-4xl font-display font-black"
        aria-label="PowerHop home"
      >
        <span>POWER</span><span>HOP</span>
      </a>
      <a
        href="/"
        class="mobileOpenLogo text-4xl font-display font-black"
        aria-label="PowerHop home"
      >
        <span>POWER</span><span>HOP</span>
      </a>
      <!-- Hamburger -->
      <button
        type="button"
        class="hamburger"
        id="hamburger"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <!-- Mobile -->
    <nav id="mobileMenu" class="hidden">
      <a
        href="/"
        class=`font-display text-brand font-black text-4xl ${activeClass("/")}`
        >Home</a
      >
      <a
        href="/services/"
        class=`font-display text-brand font-black text-4xl ${activeClass("/services/")}`
        >Our services</a
      >
      <a
        href="/about/"
        class=`font-display text-brand font-black text-4xl ${activeClass("/about/")}`
        >About us</a
      >
      <a
        href="/faq/"
        class=`font-display text-brand font-black text-4xl ${activeClass("/faq/")}`
        >FAQ</a
      >
      <a
        href="/profile/"
        class=`font-display text-brand font-black text-4xl ${activeClass("/profile/")}`
        >Log in</a
      >
    </nav>

    <!-- Desktop -->
    <div class="desktopMenu">
      <div id="desktopGrid">
        <a
          href="/"
          class="mobileClosedLogo text-4xl font-display font-black"
          aria-label="PowerHop home"
        >
          <span>POWER</span><span>HOP</span>
        </a>
        <div id="desktopNav">
          <a
            href="/"
            class=`font-display text-brand font-black text-4xl ${activeClass("/")}`
            >Home</a
          >
          <a
            href="/services/"
            class=`font-display text-brand font-black text-4xl ${activeClass("/services/")}`
            >Our Services</a
          >
          <a
            href="/faq/"
            class=`font-display text-brand font-black text-4xl ${activeClass("/faq/")}`
            >FAQ</a
          >
          <a
            href="/about/"
            class=`font-display text-brand font-black text-4xl ${activeClass("/about/")}`
            >About Us</a
          >
          <a
            href="/profile/"
            id="profileLink"
            class=`font-display text-brand font-black text-4xl ${activeClass("/profile/")}`
            >Log in</a
          >
        </div>
      </div>
    </div>
  </div>

  <script type="module">
    const siteHeader = document.getElementById("siteHeader");
    const hamburger = document.getElementById("hamburger");
    const mobileMenu = document.getElementById("mobileMenu");

    const setMobileMenuOpen = (isOpen) => {
      mobileMenu.classList.toggle("hidden", !isOpen);
      siteHeader.classList.toggle("mobile-menu-open", isOpen);
      hamburger.setAttribute("aria-expanded", String(isOpen));
    };

    hamburger.addEventListener("click", () => {
      setMobileMenuOpen(mobileMenu.classList.contains("hidden"));
    });

    document.addEventListener("click", (event) => {
      const isOpen = !mobileMenu.classList.contains("hidden");

      if (isOpen && !siteHeader.contains(event.target)) {
        setMobileMenuOpen(false);
      }
    });
  </script>

  <style>
    header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: #f7f7f7;
      border-bottom: 1px solid #aaaaaa;
    }

    a {
      text-transform: uppercase;
      text-decoration: none;
      color: #0a0a0a;
    }

    #profile-log-in {
      text-decoration: underline;
      text-decoration-thickness: 0.12em;
      text-underline-offset: 0.12em;
    }

    a:hover {
      /* change to tailwind class */
      color: #008751;
    }

    #desktopNav a.active,
    #mobileMenu a.active {
      color: #004d2e;
      text-decoration: underline;
      text-decoration-color: #004d2e;
      text-decoration-thickness: 0.12em;
      text-underline-offset: 0.18em;
    }

    /* mobile specific styling */
    #mobileAlwaysVisible {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem;
    }

    .headerLogo {
      display: block;
    }

    .mobileOpenLogo {
      display: none;
      color: #f5f5f5;
    }

    .mobileClosedLogo span:last-child {
      color: #008751;
    }

    .mobileOpenLogo span:last-child {
      color: #008751;
    }

    .hamburger {
      display: grid;
      place-items: center;
      width: 4rem;
      height: 1rem;
      padding: 0;
      border: 0;
      background: transparent;
      cursor: pointer;
    }

    .hamburger span {
      grid-area: 1 / 1;
      width: 2.75rem;
      height: 0.3rem;
      border-radius: 999px;
      background: #008751;
      transition:
        transform 150ms ease,
        opacity 150ms ease;
    }

    .hamburger span:first-child {
      transform: translateY(-0.85rem);
    }

    .hamburger span:last-child {
      transform: translateY(0.85rem);
    }

    #mobileMenu {
      display: flex;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0.6rem;
      padding: 2rem 2rem 7rem 2rem;
      background: #0a0a0a;
      clip-path: polygon(0 0, 100% 0, 100% 100%, 0 calc(100% - 86px));
      text-align: right;
    }

    /* hide desktop version when on mobile */
    .desktopMenu {
      display: none;
    }

    #mobileMenu.hidden {
      display: none;
    }

    @media (max-width: 767px) {
      header {
        position: fixed;
        right: 0;
        left: 0;
      }

      header.mobile-menu-open {
        background: #0a0a0a;
        border-bottom: 0;
      }

      header.mobile-menu-open #mobileAlwaysVisible {
        border-bottom: 1px solid #e0e0e0;
      }

      header.mobile-menu-open .mobileClosedLogo {
        display: none;
      }

      header.mobile-menu-open .mobileOpenLogo {
        display: inline-flex;
      }

      header.mobile-menu-open .hamburger span:first-child {
        transform: rotate(20deg);
      }

      header.mobile-menu-open .hamburger span:nth-child(2) {
        opacity: 0;
      }

      header.mobile-menu-open .hamburger span:last-child {
        transform: rotate(-20deg);
      }

      header.mobile-menu-open #mobileMenu a {
        color: #f5f5f5;
      }

      header.mobile-menu-open #mobileMenu a.active {
        color: #00a862;
        text-decoration: underline;
        text-decoration-color: #00a862;
        text-decoration-thickness: 0.12em;
        text-underline-offset: 0.18em;
      }
    }

    @media (min-width: 768px) {
      /* hide mobile version when on desktop */
      #mobileAlwaysVisible,
      #mobileMenu {
        display: none;
      }

      .desktopMenu {
        display: block;
      }

      #desktopGrid {
        display: grid;
        grid-template-columns: auto auto;
        padding: 1rem;
      }
      #desktopNav {
        display: flex;
        gap: 2rem;
        justify-content: flex-end;
      }
    }
  </style>
</header>
