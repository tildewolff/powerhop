---
import logo from "../assets/logo.svg";
import "../styles/global.css";

// get page prop from loaded page
const Page = Astro.props.Page;
---

<header id="siteHeader" class="bg-light-surface">
  <div class="headerContents">
    <!-- logos -->
    <div id="mobileAlwaysVisible">
      <a
        href="/index.html"
        class="mobileClosedLogo text-hero font-display font-black"
        aria-label="PowerHop home"
      >
        <span>POWER</span><span>HOP</span>
      </a>
      <a
        href="/index.html"
        class="mobileOpenLogo text-hero font-display font-black"
        aria-label="PowerHop home"
      >
        <span>POWER</span><span>HOP</span>
      </a>
      <!-- Hamburger -->
      <button
        type="button"
        class="hamburger"
        id="hamburger"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <!-- Mobile -->
    <nav id="mobileMenu" class="hidden">
      <a
        href="/index.html"
        class=`font-display text-brand font-black text-hero ${Page==="Home" ? 'active':''}`
        >Home</a
      >
      <a
        href="/OurServices"
        class=`font-display text-brand font-black text-hero${Page==="OurServices" ? 'active':''}`
        >Our services</a
      >
      <a
        href="/AboutUs"
        class=`font-display text-brand font-black text-hero${Page==="AboutUs" ? 'active':''}`
        >About us</a
      >
      <a
        href="/FAQ"
        class=`font-display text-brand font-black text-hero${Page==="FAQ" ? 'active':''}`
        >FAQ</a
      >
      <a
        href="/Profile"
        class=`font-display text-brand font-black text-hero${Page==="Profile" ? 'active':''}`
        >Log in</a
      >
    </nav>

    <!-- Desktop -->
    <div class="desktopMenu">
      <div id="desktopGrid">
        <a
          href="/index.html"
          class="mobileClosedLogo text-4xl font-display font-black"
          aria-label="PowerHop home"
        >
          <span>POWER</span><span>HOP</span>
        </a>
        <div id="desktopNav">
          <a
            href="/index.html"
            class=`font-display text-brand font-black text-4xl ${Page==="Home" ? 'active':''}`
            >Home</a
          >
          <a
            href="/OurServices"
            class=`font-display text-brand font-black text-4xl${Page==="OurServices" ? 'active':''}`
            >Our Services</a
          >
          <a
            href="/FAQ"
            class=`font-display text-brand font-black text-4xl${Page==="FAQ" ? 'active':''}`
            >FAQ</a
          >
          <a
            href="/AboutUs"
            class=`font-display text-brand font-black text-4xl${Page==="AboutUs" ? 'active':''}`
            >About Us</a
          >
          <a
            href="/Profile"
            id="profileLink"
            class=`font-display text-brand underline font-black text-4xl${Page==="Profile" ? 'active':''}`
            >Log in</a
          >
        </div>
      </div>
    </div>
  </div>

  <script type="module">
    const siteHeader = document.getElementById("siteHeader");
    const hamburger = document.getElementById("hamburger");
    const mobileMenu = document.getElementById("mobileMenu");

    hamburger.addEventListener("click", () => {
      const isOpen = mobileMenu.classList.toggle("hidden") === false;
      siteHeader.classList.toggle("mobile-menu-open", isOpen);
      hamburger.setAttribute("aria-expanded", String(isOpen));
    });
  </script>

  <style>
    header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: #f7f7f7;
      border-bottom: 1px solid #aaaaaa;
    }

    a {
      text-transform: uppercase;
      text-decoration: none;
      color: #0a0a0a;
    }

    #profile-log-in {
      text-decoration: underline;
      text-decoration-thickness: 0.12em;
      text-underline-offset: 0.12em;
    }

    a:hover {
      /* change to tailwind class */
      color: #008751;
    }

    /* mobile specific styling */
    #mobileAlwaysVisible {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem;
    }

    .headerLogo {
      display: block;
    }

    .mobileOpenLogo {
      display: none;
      color: #f5f5f5;
    }

    .mobileClosedLogo span:last-child {
      color: #008751;
    }

    .mobileOpenLogo span:last-child {
      color: #008751;
    }

    .hamburger {
      display: grid;
      place-items: center;
      width: 4rem;
      height: 3.5rem;
      padding: 0;
      border: 0;
      background: transparent;
      cursor: pointer;
    }

    .hamburger span {
      grid-area: 1 / 1;
      width: 3.9rem;
      height: 0.4rem;
      border-radius: 999px;
      background: #008751;
      transition:
        transform 150ms ease,
        opacity 150ms ease;
    }

    .hamburger span:first-child {
      transform: translateY(-0.85rem);
    }

    .hamburger span:last-child {
      transform: translateY(0.85rem);
    }

    #mobileMenu {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      padding: 2rem 2rem 7rem 2rem;
      text-align: right;
    }

    /* hide desktop version when on mobile */
    .desktopMenu {
      display: none;
    }

    #mobileMenu.hidden {
      display: none;
    }

    @media (max-width: 767px) {
      header.mobile-menu-open {
        background: #000000;
        border-bottom: 0;
        /* shape the angled bottom: */
        clip-path: polygon(0 0, 100% 0, 100% 100%, 0 calc(100% - 86px));
      }

      header.mobile-menu-open #mobileAlwaysVisible {
        border-bottom: 1px solid #aaaaaa;
      }

      header.mobile-menu-open .mobileClosedLogo {
        display: none;
      }

      header.mobile-menu-open .mobileOpenLogo {
        display: inline-flex;
      }

      header.mobile-menu-open .hamburger span:first-child {
        transform: rotate(20deg);
      }

      header.mobile-menu-open .hamburger span:nth-child(2) {
        opacity: 0;
      }

      header.mobile-menu-open .hamburger span:last-child {
        transform: rotate(-20deg);
      }

      header.mobile-menu-open #mobileMenu a {
        color: white;
      }

      header.mobile-menu-open #mobileMenu a:last-child {
        color: #e0f3eb;
        text-decoration: underline;
        text-decoration-thickness: 0.12em;
        text-underline-offset: 0.12em;
      }
    }

    @media (min-width: 768px) {
      /* hide mobile version when on desktop */
      #mobileAlwaysVisible,
      #mobileMenu {
        display: none;
      }

      .desktopMenu {
        display: block;
      }

      #desktopGrid {
        display: grid;
        grid-template-columns: auto auto;
        padding: 1rem;
      }
      #desktopNav {
        display: flex;
        gap: 2rem;
        justify-content: flex-end;
      }
    }
  </style>
</header>
