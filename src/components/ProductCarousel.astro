---
import { Image } from "astro:assets";

interface CarouselImage {
  src: ImageMetadata;
  alt: string;
}

interface Props {
  images: CarouselImage[];
}

const { images } = Astro.props;
---

<section class="product-carousel" aria-label="Product images" tabindex="0">
  <button
    class="carousel-arrow carousel-arrow-left"
    type="button"
    aria-label="Previous product image"
    data-carousel-previous></button>

  <div class="carousel-frame">
    {
      images.map((image, index) => (
        <Image
          src={image.src}
          alt={image.alt}
          class={`carousel-image ${index === 0 ? "is-active" : ""}`}
          width={520}
          data-carousel-image
        />
      ))
    }
  </div>

  <button
    class="carousel-arrow carousel-arrow-right"
    type="button"
    aria-label="Next product image"
    data-carousel-next></button>

  <div class="carousel-dots" aria-label="Choose product image">
    {
      images.map((_, index) => (
        <button
          class={`carousel-dot ${index === 0 ? "is-active" : ""}`}
          type="button"
          aria-label={`Show product image ${index + 1}`}
          aria-pressed={index === 0 ? "true" : "false"}
          data-carousel-dot
          data-carousel-index={index}
        />
      ))
    }
  </div>
</section>

<script>
  const carousel =
    document.querySelector<HTMLElement>(".product-carousel");
  const images = Array.from(
    document.querySelectorAll<HTMLElement>("[data-carousel-image]"),
  );
  const dots = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-carousel-dot]"),
  );
  const previousButton = document.querySelector<HTMLButtonElement>(
    "[data-carousel-previous]",
  );
  const nextButton = document.querySelector<HTMLButtonElement>(
    "[data-carousel-next]",
  );

  let activeIndex = 0;

  const showImage = (nextIndex: number) => {
    activeIndex = (nextIndex + images.length) % images.length;

    images.forEach((image, index) => {
      image.classList.toggle("is-active", index === activeIndex);
    });

    dots.forEach((dot, index) => {
      const isActive = index === activeIndex;
      dot.classList.toggle("is-active", isActive);
      dot.setAttribute("aria-pressed", String(isActive));
    });
  };

  previousButton?.addEventListener("click", () => showImage(activeIndex - 1));
  nextButton?.addEventListener("click", () => showImage(activeIndex + 1));

  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      showImage(Number(dot.dataset.carouselIndex || 0));
    });
  });

  carousel?.addEventListener("keydown", (event) => {
    if (event.key === "ArrowLeft") {
      showImage(activeIndex - 1);
    }

    if (event.key === "ArrowRight") {
      showImage(activeIndex + 1);
    }
  });
</script>

<style>
  .product-carousel {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    width: min(100%, 24rem);
  }

  .carousel-frame {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 1 / 1.05;
    border: 1px solid #9f9f9f;
    background: #ffffff;
    overflow: hidden;
  }

  .carousel-image {
    position: absolute;
    width: 86%;
    height: 86%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 160ms ease;
  }

  .carousel-image.is-active {
    opacity: 1;
  }

  .carousel-arrow {
    width: 1.65rem;
    height: 3rem;
    border: 0;
    background: transparent;
    cursor: pointer;
    position: relative;
  }

  .carousel-arrow::before {
    content: "";
    position: absolute;
    inset: 0;
    width: 1.4rem;
    height: 1.4rem;
    margin: auto;
    border-top: 2px solid #111111;
    border-right: 2px solid #111111;
  }

  .carousel-arrow-left::before {
    transform: rotate(-135deg);
  }

  .carousel-arrow-right::before {
    transform: rotate(45deg);
  }

  .carousel-dots {
    grid-column: 1 / -1;
    display: flex;
    justify-content: center;
    gap: 0.25rem;
    margin-top: 0.75rem;
  }

  .carousel-dot {
    width: 0.55rem;
    height: 0.55rem;
    border: 1px solid #777777;
    border-radius: 999px;
    background: transparent;
    cursor: pointer;
    padding: 0;
  }

  .carousel-dot.is-active {
    border-color: #008751;
    background: #008751;
  }

  .carousel-arrow:focus-visible,
  .carousel-dot:focus-visible {
    outline: 2px solid #008751;
    outline-offset: 3px;
  }
</style>
