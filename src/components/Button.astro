---
/**
 * Props:
 *  - href       (string, required)  – destination URL
 *  - text       (string, optional)  – button label; defaults per variant
 *  - variant    (1 | 2 | 3 | 4)    – visual style; defaults to 1
 *  - target     (string, optional)  – e.g. "_blank"
 *  - class      (string, optional)  – extra classes passed from the parent
 */

interface Props {
  href: string;
  text?: string;
  variant?: 1 | 2 | 3 | 4;
  target?: string;
  class?: string;
}

const { href, variant = 1, target, class: extraClass = "" } = Astro.props;

// Default label per variant (variant 4 is "previous", others are "read more")
const defaultText = variant === 4 ? "← Previous" : "Read more →";
const text = Astro.props.text ?? defaultText;

// Map variant number → CSS modifier class
const variantClasses = {
  1: "font-sans text-base bg-brand text-dark-primary border-brand hover:bg-brand-light hover:border-brand-light hover:shadow-brand",
  2: "font-sans text-base bg-brand-accent text-light-primary border-brand-accent hover:bg-dark-primary hover:border-dark-primary hover:shadow-brand:",
  3: "font-sans text-base bg-dark-bg text-dark-primary border-dark-bg hover:bg-dark-subtle hover:border-dark-subtle hover:shadow-dark-primary",
  4: "font-sans text-base bg-light-bg text-light-primary border-light-secondary hover:bg-light-surface hover:border-light-surface hover:shadow-light-primary",
};

const variantClass = variantClasses[variant];
---

<a
  href={href}
  target={target}
  class={`btn ${variantClass} ${extraClass}`.trim()}
>
  {text}
</a>

<style>
  /* ── Base button ───────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    text-transform: uppercase;
    align-items: center;
    justify-content: center;
    min-width: 135px;
    padding: 0.55em 1.35em;
    border-radius: 999px; /* fully rounded / pill shape  */
    border: 2px solid transparent;
    font-family: inherit;
    /* font-size: 0.95rem; */
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    cursor: pointer;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      border-color 150ms ease,
      box-shadow 150ms ease,
      transform 100ms ease;
    white-space: nowrap;
  }

  .btn:hover {
    /* transform: translateY(-1px); */
  }
  .btn:active {
    transform: translateY(0);
  }

