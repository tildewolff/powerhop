---
// Reusable styled checkbox option for booking add-ons.
interface Props {
  id: string;
  name: string;
  label: string;
  value: string;
  price: string;
  inputWatts: string;
  checked?: boolean;
}

const {
  id,
  name,
  label,
  value,
  price,
  inputWatts,
  checked = false,
} = Astro.props;
---

<!-- The real checkbox still submits with the form; the card is the visual UI. -->
<label class="addon-option" for={id}>
  <input
    id={id}
    type="checkbox"
    name={name}
    value={value}
    checked={checked}
  />

  <span class="addon-card">
    <span class="addon-copy">
      <span
        class="addon-name mb-2 font-display text-3xl font-bold leading-none tracking-normal uppercase"
      >
        {label}
      </span>
      <span class="addon-spec font-mono text-lg">+ {price} / MONTH</span>
      <span class="addon-spec font-mono text-lg">{inputWatts} W EXTRA INPUT</span
      >
      <span class="addon-link text-light-muted">Full details</span>
    </span>

    <span class="addon-check" aria-hidden="true"></span>
  </span>
</label>

<style>
  .addon-option {
    display: block;
    cursor: pointer;
  }

  .addon-option input {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .addon-card {
    position: relative;
    display: block;
    min-height: 6.5rem;
    border: 1px solid #b7b7b7;
    background: #ffffff;
    color: #a9a9a9;
    opacity: 0.75;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease,
      opacity 160ms ease;
  }

  .addon-option input:checked + .addon-card {
    border-color: #009f5c;
    background: #e7f4ed;
    color: #111111;
    opacity: 1;
  }

  .addon-option input:focus-visible + .addon-card {
    outline: 3px solid #111111;
    outline-offset: 3px;
  }

  .addon-copy {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 3rem 0.55rem 1rem;
    min-width: 0;
    line-height: 1.08;
  }

  .addon-name {
    display: block;
    color: #111111;
  }

  .addon-option input:checked + .addon-card .addon-name {
    color: #009f5c;
  }

  .addon-spec {
    font-size: 0.9rem;
    text-transform: uppercase;
  }

  .addon-link {
    width: fit-content;
    margin-top: 0.55rem;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 0.7rem;
    text-decoration: underline;
  }

  .addon-check {
    position: absolute;
    top: 0.65rem;
    right: 0.75rem;
    width: 1rem;
    height: 1rem;
    border: 2px solid #666666;
    border-radius: 9999px;
    background: #ffffff;
  }

  .addon-option input:checked + .addon-card .addon-check {
    border-color: #009f5c;
  }

  .addon-option input:checked + .addon-card .addon-check::after {
    content: "";
    position: absolute;
    inset: 0.2rem;
    border-radius: inherit;
    background: #009f5c;
  }
</style>
